{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "pets"
  ],
  "additionalProperties": false,

  "properties": {
    "$schema": {
      "type": "string"
    },

    "pets": {
      "type": "object",
      "required": [
        "LEPRECHAUN",
        "TURTLE",
        "BEAR",
        "BLACK_CAT",
        "WOLF"
      ],
      "additionalProperties": false,

      "properties": {
        "LEPRECHAUN": {
          "$ref": "#/$defs/pet"
        },
        "TURTLE": {
          "$ref": "#/$defs/pet"
        },
        "BEAR": {
          "$ref": "#/$defs/pet"
        },
        "BLACK_CAT": {
          "$ref": "#/$defs/pet"
        },
        "WOLF": {
          "$ref": "#/$defs/pet"
        }
      }
    }
  },

  "$defs": {
    "pet": {
      "type": "object",
      "required": [
        "title",
        "description",
        "texture",
        "rarity",
        "icon",
        "levels"
      ],
      "additionalProperties": false,

      "properties": {
        "title": {
          "type": "string"
        },

        "description": {
          "type": "string"
        },

        "texture": {
          "$ref": "./common.schema.json#/$defs/itemStack"
        },

        "rarity": {
          "$ref": "./common.schema.json#/$defs/rarity"
        },

        "icon": {
          "type": "string"
        },

        "requiredFragments": {
          "type": "integer",
          "minimum": 0
        },

        "levels": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/petLevel"
          }
        }
      }
    },

    "petLevel": {
      "type": "object",
      "required": [
        "maxHealth",
        "attackCooldown",
        "damage"
      ],
      "additionalProperties": false,

      "properties": {
        "maxHealth": {
          "type": "number"
        },

        "attackCooldown": {
          "type": "number"
        },

        "takeDamageChance": {
          "type": "number"
        },

        "takeDamageAmount": {
          "type": "number"
        }
      }
    }
  }
}